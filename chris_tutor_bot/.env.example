# .env — Copy this file and fill in your values
# NEVER share this file or commit it to GitHub

# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Ollama model to use for AI explanations (must be pulled locally)
# Options: llama3, mistral, gemma, phi3
OLLAMA_MODEL=llama3

# Ollama API URL (default works if running locally)
OLLAMA_URL=http://localhost:11434/api/generate

# Optional: lock down the Flask API with a secret key
# Leave blank to allow all requests (fine for local use)
API_KEY=

# Port for the Flask API server (default 5000)
PORT=5000
